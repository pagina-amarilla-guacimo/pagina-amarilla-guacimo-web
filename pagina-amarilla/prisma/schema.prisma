

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Store{
  id Int @id @default(autoincrement())
  name String 
  description String
  phoneNumber String
  location String
  image String?
  categoryId Int
  category Category @relation(fields: [categoryId], references: [id])
} 

model Category{
  id Int @id @default(autoincrement())
  name String
  stores Store[]
}

model Admin{
  id Int @id @default(autoincrement())
  name String
  email String @unique
  password String
  createdAt DateTime @default(now())
}