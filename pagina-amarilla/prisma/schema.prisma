

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Store{
  id Int @id @default(autoincrement())
  name String 
  description String
  phoneNumber String
  district String @default("Guácimo")
  location String
  image String?
  categoryId Int
  category Category @relation(fields: [categoryId], references: [id])
  isActive Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
} 

model Category{
  id Int @id @default(autoincrement())
  name String
  stores Store[]
  isActive Boolean @default(true)
}

model Admin{
  id Int @id @default(autoincrement())
  name String
  email String @unique
  password String
  createdAt DateTime @default(now())
}